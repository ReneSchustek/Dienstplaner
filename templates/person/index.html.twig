{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}{{ 'title.persons'|trans }}{% endblock %}
{% block page_title %}{{ 'title.persons'|trans }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ 'title.persons'|trans }}</h1>
        <a href="{{ path('person_new') }}" class="btn btn-primary">{{ 'btn.new.person'|trans }}</a>
    </div>
    <form method="get" class="mb-3">
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <input type="hidden" name="sort" value="{{ sort }}">
            <input type="hidden" name="dir" value="{{ dir }}">
            <input type="text" name="q" class="form-control form-control-sm" style="max-width:280px;"
                   value="{{ q }}" placeholder="{{ 'filter.search_placeholder'|trans }}">
            <button type="submit" class="btn btn-sm btn-outline-secondary">{{ 'btn.search'|trans }}</button>
            {% if q %}<a href="{{ path('person_index', {sort: sort, dir: dir}) }}" class="btn btn-sm btn-outline-secondary">✕</a>{% endif %}
        </div>
        {% if q %}<p class="text-muted small mt-1">{{ 'filter.results_for'|trans({'%count%': total, '%q%': q}) }}</p>{% endif %}
    </form>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        {{ macros.sort_th('table.name'|trans,     'name',  sort, dir, 'person_index', {q: q}) }}
                        {{ macros.sort_th('table.email'|trans,    'email', sort, dir, 'person_index', {q: q}) }}
                        <th>{{ 'table.phone'|trans }}</th>
                        <th>{{ 'table.assembly'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for person in persons %}
                    <tr>
                        <td>{{ person.name }}</td>
                        <td>{{ person.email ?? '–' }}</td>
                        <td>{{ person.phone ?? '–' }}</td>
                        <td>{{ person.assembly.name }}</td>
                        <td class="text-end">
                            <a href="{{ path('person_edit', {id: person.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'btn.edit'|trans }}</a>
                            <form method="post" action="{{ path('person_delete', {id: person.id}) }}" class="d-inline"
                                  onsubmit="return confirm('{{ 'confirm.delete'|trans }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-person-' ~ person.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'btn.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-muted text-center">{{ 'msg.no.persons'|trans }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {{ include('_pagination.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}
