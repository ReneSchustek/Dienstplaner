{% extends 'base.html.twig' %}
{% import '_macros.html.twig' as macros %}

{% block title %}{{ 'title.absences'|trans }}{% endblock %}
{% block page_title %}{{ 'title.absences'|trans }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2 no-print">
        <h1>{{ 'title.absences'|trans }}</h1>
        <div class="d-flex gap-2">
            {% if assembly is not null %}
            {% if assembly.teamupCalendarUrl %}
            <form method="post" action="{{ path('absence_teamup_import') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('absence-teamup-import') }}">
                <button type="submit" class="btn btn-outline-secondary">
                    {{ 'btn.teamup_import'|trans }}
                </button>
            </form>
            {% else %}
            <button type="button" class="btn btn-outline-secondary disabled" aria-disabled="true"
                    data-bs-toggle="tooltip" title="{{ 'flash.teamup.no_url'|trans }}">
                {{ 'btn.teamup_import'|trans }}
            </button>
            {% endif %}
            {% endif %}
            <button type="button" class="btn btn-outline-secondary" onclick="window.print()">{{ 'btn.print'|trans }}</button>
            <a href="{{ path('absence_new') }}" class="btn btn-primary">{{ 'btn.new.absence'|trans }}</a>
        </div>
    </div>
    {% if assembly is not null and not assembly.teamupCalendarUrl %}
    <div class="alert alert-warning d-flex align-items-center gap-2 no-print" role="alert">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span>
            {{ 'flash.teamup.no_url'|trans }}
            {% if is_granted('ROLE_ASSEMBLY_ADMIN') %}
            <a href="{{ path('assembly_edit', {id: assembly.id}) }}" class="alert-link ms-1">{{ 'flash.teamup.configure_link'|trans }}</a>
            {% else %}
            {{ 'flash.teamup.no_url_hint'|trans }}
            {% endif %}
        </span>
    </div>
    {% endif %}

    <div class="print-only mb-3">
        <h2>{{ 'title.absences'|trans }}</h2>
    </div>

    {# Filter- und Suchleiste #}
    <form method="get" class="mb-3 no-print">
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <input type="hidden" name="sort" value="{{ sort }}">
            <input type="hidden" name="dir" value="{{ dir }}">
            <input type="text" name="q" class="form-control form-control-sm" style="max-width:220px;"
                   value="{{ q }}" placeholder="{{ 'filter.search_placeholder'|trans }}">
            <select name="month" class="form-select form-select-sm" style="max-width:130px;" onchange="this.form.submit()">
                <option value="0"{{ selectedMonth == 0 ? ' selected' : '' }}>{{ 'filter.all_months'|trans }}</option>
                {% for num, name in monthNames %}
                    <option value="{{ num }}"{{ selectedMonth == num ? ' selected' : '' }}>{{ name }}</option>
                {% endfor %}
            </select>
            <select name="year" class="form-select form-select-sm" style="max-width:100px;" onchange="this.form.submit()">
                <option value="0"{{ selectedYear == 0 ? ' selected' : '' }}>{{ 'filter.all_years'|trans }}</option>
                {% for yr in yearOptions %}
                    <option value="{{ yr }}"{{ selectedYear == yr ? ' selected' : '' }}>{{ yr }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-sm btn-outline-secondary">{{ 'btn.search'|trans }}</button>
            {% if q or selectedMonth or selectedYear %}
                <a href="{{ path('absence_index', {sort: sort, dir: dir}) }}" class="btn btn-sm btn-outline-secondary">✕</a>
            {% endif %}
        </div>
        {% if q %}<p class="text-muted small mt-1">{{ 'filter.results_for'|trans({'%count%': total, '%q%': q}) }}</p>{% endif %}
    </form>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        {{ macros.sort_th('table.person'|trans, 'person',    sort, dir, 'absence_index', {q: q, month: selectedMonth, year: selectedYear}) }}
                        {{ macros.sort_th('table.from'|trans,   'startDate', sort, dir, 'absence_index', {q: q, month: selectedMonth, year: selectedYear}) }}
                        {{ macros.sort_th('table.to'|trans,     'endDate',   sort, dir, 'absence_index', {q: q, month: selectedMonth, year: selectedYear}) }}
                        <th>{{ 'table.note'|trans }}</th>
                        <th class="no-print"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for absence in absences %}
                    <tr>
                        <td>{{ absence.person.name }}</td>
                        <td>{{ absence.startDate|date('d.m.Y') }}</td>
                        <td>{{ absence.endDate|date('d.m.Y') }}</td>
                        <td>{{ absence.note ?? '–' }}</td>
                        <td class="text-end no-print">
                            <a href="{{ path('absence_edit', {id: absence.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'btn.edit'|trans }}</a>
                            <form method="post" action="{{ path('absence_delete', {id: absence.id}) }}" class="d-inline"
                                  onsubmit="return confirm('{{ 'confirm.delete'|trans }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-absence-' ~ absence.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'btn.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-muted text-center">{{ 'msg.no.absences'|trans }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {{ include('_pagination.html.twig') }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
    new bootstrap.Tooltip(el);
});
</script>
{% endblock %}
