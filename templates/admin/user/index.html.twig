{% extends 'base.html.twig' %}

{% block title %}{{ 'title.users'|trans }}{% endblock %}
{% block page_title %}{{ 'title.users'|trans }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ 'title.users'|trans }}</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newUserModal">
            {{ 'btn.new.user'|trans }}
        </button>
    </div>
    <form method="get" class="mb-3">
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <input type="text" name="q" class="form-control form-control-sm" style="max-width:280px;"
                   value="{{ q }}" placeholder="{{ 'filter.search_placeholder'|trans }}">
            <button type="submit" class="btn btn-sm btn-outline-secondary">{{ 'btn.search'|trans }}</button>
            {% if q %}<a href="{{ path('admin_user_index') }}" class="btn btn-sm btn-outline-secondary">✕</a>{% endif %}
        </div>
        {% if q %}<p class="text-muted small mt-1">{{ 'filter.results_for'|trans({'%count%': total, '%q%': q}) }}</p>{% endif %}
    </form>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>{{ 'table.email'|trans }}</th>
                        <th>{{ 'table.role'|trans }}</th>
                        <th>{{ 'table.assembly'|trans }}</th>
                        <th>{{ 'table.department'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td>{{ user.email }}</td>
                        <td><span class="badge bg-secondary">{{ user.role }}</span></td>
                        <td>{{ user.assembly ? user.assembly.name : '–' }}</td>
                        <td>{{ user.departments is not empty ? user.departments|map(d => d.name)|join(', ') : '–' }}</td>
                        <td class="text-end">
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'btn.edit'|trans }}</a>
                            {% if user.calendarToken %}
                            <form method="post" action="{{ path('admin_user_send_calendar_link', {id: user.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('send-calendar-link-' ~ user.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="{{ 'btn.send_calendar_link'|trans }}">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </button>
                            </form>
                            {% endif %}
                            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" class="d-inline"
                                  onsubmit="return confirm('{{ 'confirm.delete'|trans }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ user.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'btn.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-muted text-center">{{ 'msg.no.users'|trans }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {{ include('_pagination.html.twig') }}
        </div>
    </div>
</div>

<div class="modal fade" id="newUserModal" tabindex="-1" aria-labelledby="newUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newUserModalLabel">{{ 'btn.new.user'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'btn.cancel'|trans }}"></button>
            </div>
            {{ form_start(newUserForm) }}
            <div class="modal-body">
                <div class="mb-3">
                    {{ form_label(newUserForm.name) }}
                    {{ form_widget(newUserForm.name) }}
                    {{ form_errors(newUserForm.name) }}
                </div>
                <div class="mb-3">
                    {{ form_label(newUserForm.email) }}
                    {{ form_widget(newUserForm.email) }}
                    {{ form_errors(newUserForm.email) }}
                </div>
                <div class="mb-3">
                    {{ form_label(newUserForm.role) }}
                    {{ form_widget(newUserForm.role, {attr: {id: 'new_user_role'}}) }}
                    {{ form_errors(newUserForm.role) }}
                </div>
                <div class="mb-3" id="new-field-assembly">
                    {{ form_label(newUserForm.assembly) }}
                    {{ form_widget(newUserForm.assembly) }}
                    {{ form_errors(newUserForm.assembly) }}
                </div>
                <div class="mb-3" id="new-field-department">
                    {{ form_label(newUserForm.departments) }}
                    {{ form_widget(newUserForm.departments) }}
                    {{ form_errors(newUserForm.departments) }}
                </div>
                <div class="mb-3">
                    {{ form_label(newUserForm.twoFactorRequired) }}
                    {{ form_widget(newUserForm.twoFactorRequired) }}
                    {{ form_errors(newUserForm.twoFactorRequired) }}
                </div>
                {{ form_rest(newUserForm) }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'btn.cancel'|trans }}</button>
                <button type="submit" class="btn btn-primary">{{ 'btn.save'|trans }}</button>
            </div>
            {{ form_end(newUserForm) }}
        </div>
    </div>
</div>

{% block javascripts %}
<script>
(function () {
    var roleSelect = document.getElementById('new_user_role');
    if (!roleSelect) return;

    var fieldAssembly   = document.getElementById('new-field-assembly');
    var fieldDepartment = document.getElementById('new-field-department');

    function updateNewUserFields() {
        var role = roleSelect.value;
        var showAssembly = (role === 'ROLE_ASSEMBLY_ADMIN' || role === 'ROLE_ADMIN');
        var showDept = (role === 'ROLE_PLANER');

        if (fieldAssembly) fieldAssembly.style.display = showAssembly ? '' : 'none';
        if (fieldDepartment) fieldDepartment.style.display = showDept ? '' : 'none';
    }

    roleSelect.addEventListener('change', updateNewUserFields);
    updateNewUserFields();
})();
</script>
{% endblock %}
{% endblock %}
