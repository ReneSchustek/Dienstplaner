<header style="background:#fff; border-bottom:1px solid #dee2e6; padding:12px 0; margin-bottom:24px;">
    <div style="max-width:960px; margin:0 auto; padding:0 16px; display:flex; align-items:center; gap:16px;">
        <img src="/images/logo.webp" alt="Dienstplaner" width="48" height="48" style="flex-shrink:0;">
        <div>
            <div style="font-size:1.1rem; font-weight:600; line-height:1.2;">{{ appName }}</div>
            {% if subtitle is defined and subtitle %}<div style="color:#6c757d; font-size:0.85rem;">{{ subtitle }}</div>{% endif %}
        </div>
    </div>
</header>
