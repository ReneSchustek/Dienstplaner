{% if pages > 1 %}
<nav aria-label="{{ 'pagination.label'|trans }}" class="mt-3">
    <div class="d-flex align-items-center gap-2 flex-wrap">
        {% if page > 1 %}
            <a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({page: page - 1})) }}"
               class="btn btn-sm btn-outline-secondary">{{ 'pagination.previous'|trans }}</a>
        {% else %}
            <button class="btn btn-sm btn-outline-secondary" disabled>{{ 'pagination.previous'|trans }}</button>
        {% endif %}

        <span class="text-muted small">
            {{ 'pagination.page_of'|trans({'%page%': page, '%pages%': pages}) }}
        </span>

        {% if page < pages %}
            <a href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({page: page + 1})) }}"
               class="btn btn-sm btn-outline-secondary">{{ 'pagination.next'|trans }}</a>
        {% else %}
            <button class="btn btn-sm btn-outline-secondary" disabled>{{ 'pagination.next'|trans }}</button>
        {% endif %}
    </div>
</nav>
{% endif %}
