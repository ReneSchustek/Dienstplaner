<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-theme="modern-classic">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'title.password_reset'|trans }} – Dienstplaner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,300..700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/themes.css" rel="stylesheet">
</head>
<body style="background-color: var(--color-bg); min-height: 100vh; display: flex; align-items: center; justify-content: center;">

<div style="width: 100%; max-width: 400px; padding: 24px;">
    <div class="dp-card text-center">
        <p style="font-size: 1.5rem; margin-bottom: 16px;">✉️</p>
        <h1 style="font-size: 1.1rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 12px;">
            {{ 'password_reset.sent_title'|trans }}
        </h1>
        <p style="color: var(--color-text-secondary); font-size: 0.9rem; margin-bottom: 20px;">
            {{ 'password_reset.sent_hint'|trans }}
        </p>
        <a href="{{ path('security_login') }}" class="btn btn-primary btn-sm">{{ 'btn.back_to_login'|trans }}</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
