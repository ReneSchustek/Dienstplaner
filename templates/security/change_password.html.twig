{% extends 'base.html.twig' %}

{% block title %}{{ 'title.change_password'|trans }}{% endblock %}
{% block page_title %}{{ 'title.change_password'|trans }}{% endblock %}

{% block content %}
<div class="container py-5" style="max-width: 480px;">
    <div class="dp-card">
        <h2 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 20px;">{{ 'title.change_password'|trans }}</h2>
        <p class="text-muted mb-4" style="font-size: 0.9rem;">{{ 'change_password.hint'|trans }}</p>

        <form method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('change-password') }}">

            <div class="mb-3">
                <label for="password" class="form-label">{{ 'label.new_password'|trans }}</label>
                <input type="password" id="password" name="password" class="form-control" required minlength="8">
            </div>
            <div class="mb-4">
                <label for="password_confirm" class="form-label">{{ 'label.password_confirm'|trans }}</label>
                <input type="password" id="password_confirm" name="password_confirm" class="form-control" required minlength="8">
            </div>
            <button type="submit" class="btn btn-primary w-100">{{ 'btn.save_password'|trans }}</button>
        </form>
    </div>
</div>
{% endblock %}
