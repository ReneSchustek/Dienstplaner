<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-theme="modern-classic">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'btn.login'|trans }} – Dienstplaner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,300..700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/themes.css" rel="stylesheet">
</head>
<body style="background-color: var(--color-bg); min-height: 100vh; display: flex; align-items: center; justify-content: center;">

<div style="width: 100%; max-width: 400px; padding: 24px;">
    <div class="text-center mb-4">
        <img src="/images/logo.webp" alt="Dienstplaner Logo" width="96" height="96" style="border-radius: 16px;">
        <h1 style="font-size: 1.5rem; font-weight: 700; margin-top: 16px; color: var(--color-text-primary);">Dienstplaner</h1>
        <p style="color: var(--color-text-secondary); font-size: 0.9rem;">{{ 'login.subtitle'|trans }}</p>
    </div>

    <div class="dp-card">
        {% if error %}
            <div class="alert alert-danger" role="alert">
                <strong>{{ 'login.error'|trans }}:</strong> {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('security_login') }}" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="mb-3">
                <label for="email" class="form-label">{{ 'label.email'|trans }}</label>
                <input
                    type="email"
                    id="email"
                    name="_username"
                    class="form-control"
                    value="{{ last_username }}"
                    autocomplete="email"
                    autofocus
                    required
                    aria-required="true"
                >
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">{{ 'label.password'|trans }}</label>
                <input
                    type="password"
                    id="password"
                    name="_password"
                    class="form-control"
                    autocomplete="current-password"
                    required
                    aria-required="true"
                >
            </div>

            <div class="mb-4 form-check">
                <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me" value="on">
                <label class="form-check-label" for="remember_me" style="font-size: 0.875rem; color: var(--color-text-secondary);">
                    {{ 'label.remember_me'|trans }}
                </label>
            </div>

            <button type="submit" class="btn btn-primary w-100">{{ 'btn.login'|trans }}</button>
        </form>

        <div class="text-center mt-3">
            <a href="{{ path('password_reset_request') }}" style="font-size: 0.85rem; color: var(--color-text-secondary);">
                {{ 'login.forgot_password'|trans }}
            </a>
        </div>
    </div>

    <div class="text-center mt-3 d-flex justify-content-center gap-2">
        <a href="{{ path('language_switch', {locale: 'de'}) }}" class="btn btn-outline-secondary btn-sm{{ app.request.locale == 'de' ? ' active' : '' }}" title="Deutsch"><img src="https://flagcdn.com/20x15/de.png" width="20" height="15" alt="Deutsch"></a>
        <a href="{{ path('language_switch', {locale: 'en'}) }}" class="btn btn-outline-secondary btn-sm{{ app.request.locale == 'en' ? ' active' : '' }}" title="English"><img src="https://flagcdn.com/20x15/gb.png" width="20" height="15" alt="English"></a>
        <a href="{{ path('language_switch', {locale: 'fr'}) }}" class="btn btn-outline-secondary btn-sm{{ app.request.locale == 'fr' ? ' active' : '' }}" title="Français"><img src="https://flagcdn.com/20x15/fr.png" width="20" height="15" alt="Français"></a>
    </div>

    <p class="text-center mt-3" style="font-size: 0.8rem; color: var(--color-text-secondary);">
        <a href="{{ path('legal_index') }}" style="color: inherit;">{{ 'nav.legal'|trans }}</a>
    </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
