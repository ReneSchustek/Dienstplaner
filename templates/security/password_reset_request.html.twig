<!DOCTYPE html>
<html lang="{{ app.request.locale }}" data-theme="modern-classic">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'title.password_reset'|trans }} – Dienstplaner</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Flex:opsz,wght@8..144,300..700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/themes.css" rel="stylesheet">
</head>
<body style="background-color: var(--color-bg); min-height: 100vh; display: flex; align-items: center; justify-content: center;">

<div style="width: 100%; max-width: 400px; padding: 24px;">
    <div class="text-center mb-4">
        <h1 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text-primary);">{{ 'title.password_reset'|trans }}</h1>
        <p style="color: var(--color-text-secondary); font-size: 0.9rem;">{{ 'password_reset.hint'|trans }}</p>
    </div>

    <div class="dp-card">
        <form method="post">
            <div class="mb-3">
                <label for="email" class="form-label">{{ 'label.email'|trans }}</label>
                <input type="email" id="email" name="email" class="form-control" required autofocus>
            </div>
            <button type="submit" class="btn btn-primary w-100">{{ 'btn.send_reset'|trans }}</button>
        </form>
    </div>

    <p class="text-center mt-3" style="font-size: 0.85rem;">
        <a href="{{ path('security_login') }}" style="color: var(--color-text-secondary);">← {{ 'btn.back_to_login'|trans }}</a>
    </p>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
