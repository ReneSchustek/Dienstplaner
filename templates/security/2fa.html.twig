<!DOCTYPE html>
<html lang="de" data-theme="modern-classic">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ '2fa.title'|trans }} – Dienstplaner</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/themes.css" rel="stylesheet">
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background: var(--bg-primary, #f5f5f5);">

<div class="card shadow" style="width: 360px; border-radius: 12px; border: none;">
    <div class="card-body p-4">
        <div class="text-center mb-4">
            <img src="/images/logo.webp" alt="Dienstplaner" width="64" height="64" style="border-radius: 8px;">
        </div>
        <h5 class="card-title text-center mb-1">{{ '2fa.title'|trans }}</h5>
        <p class="text-center text-muted mb-4" style="font-size: 0.9rem;">{{ '2fa.instructions'|trans }}</p>

        {% if authentication_error %}
        <div class="alert alert-danger" role="alert">
            {{ authentication_error.messageKey|trans(authentication_error.messageData, 'security') }}
        </div>
        {% endif %}

        <form method="post" action="{{ path('2fa_login_check') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa') }}">
            <div class="mb-3">
                <label for="code" class="form-label">{{ '2fa.code_label'|trans }}</label>
                <input type="text" id="code" name="_auth_code" class="form-control form-control-lg text-center"
                       inputmode="numeric" pattern="[0-9A-Z]{6,10}" autocomplete="one-time-code"
                       maxlength="10" placeholder="000000" autofocus>
            </div>
            <button type="submit" class="btn btn-primary w-100">{{ '2fa.submit'|trans }}</button>
        </form>

        <div class="text-center mt-3">
            <a href="{{ path('security_logout') }}" style="font-size: 0.85rem; color: var(--text-muted, #888);">
                {{ 'nav.logout'|trans }}
            </a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
