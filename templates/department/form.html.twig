{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ title }}</h1>
        <a href="{{ path('department_index') }}" class="btn btn-outline-secondary">{{ 'btn.back'|trans }}</a>
    </div>
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
            {{ form_widget(form) }}
            <button type="submit" class="btn btn-primary mt-3">{{ 'btn.save'|trans }}</button>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
