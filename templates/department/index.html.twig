{% extends 'base.html.twig' %}

{% block title %}{{ 'title.departments'|trans }}{% endblock %}
{% block page_title %}{{ 'title.departments'|trans }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ 'title.departments'|trans }}</h1>
        {% if not readOnly %}
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newDeptModal">
            {{ 'btn.new.department'|trans }}
        </button>
        {% endif %}
    </div>
    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>{{ 'table.name'|trans }}</th>
                        <th>{{ 'table.assembly'|trans }}</th>
                        <th>{{ 'table.tasks'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for department in departments %}
                    <tr>
                        <td>
                            {{ department.name }}
                            <span class="badge ms-2" data-dept-color="{{ department.color }}">{{ department.color }}</span>
                        </td>
                        <td>{{ department.assembly.name }}</td>
                        <td>{{ department.tasks|length }}</td>
                        <td class="text-end">
                            <a href="{{ path('department_edit', {id: department.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'btn.edit'|trans }}</a>
                            <form method="post" action="{{ path('department_delete', {id: department.id}) }}" class="d-inline"
                                  onsubmit="return confirm('{{ 'confirm.delete'|trans }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete-department-' ~ department.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'btn.delete'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="text-muted text-center">{{ 'msg.no.departments'|trans }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if not readOnly %}
<div class="modal fade" id="newDeptModal" tabindex="-1" aria-labelledby="newDeptModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="newDeptModalLabel">{{ 'btn.new.department'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'btn.cancel'|trans }}"></button>
            </div>
            {{ form_start(newDeptForm) }}
            <div class="modal-body">
                <div class="mb-3">
                    {{ form_label(newDeptForm.name) }}
                    {{ form_widget(newDeptForm.name) }}
                    {{ form_errors(newDeptForm.name) }}
                </div>
                <div class="mb-3">
                    {{ form_label(newDeptForm.color) }}
                    {{ form_widget(newDeptForm.color) }}
                    {{ form_errors(newDeptForm.color) }}
                </div>
                {{ form_rest(newDeptForm) }}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'btn.cancel'|trans }}</button>
                <button type="submit" class="btn btn-primary">{{ 'btn.save'|trans }}</button>
            </div>
            {{ form_end(newDeptForm) }}
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
