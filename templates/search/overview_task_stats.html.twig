{% extends 'base.html.twig' %}

{% block title %}{{ 'search.overview.task_stats'|trans }}{% endblock %}
{% block page_title %}{{ 'nav.search'|trans }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    {% include 'search/_nav.html.twig' with {active: 'overview_task_stats'} %}

    <div class="dp-card mb-4">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label form-label-sm">{{ 'label.from'|trans }}</label>
                <input type="date" name="from" value="{{ fromStr }}" class="form-control form-control-sm">
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm">{{ 'label.to'|trans }}</label>
                <input type="date" name="to" value="{{ toStr }}" class="form-control form-control-sm">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">{{ 'btn.search'|trans }}</button>
            </div>
            {% if rows|length > 0 %}
            <div class="col-auto">
                <a href="{{ path('search_overview_task_stats', {from: fromStr, to: toStr, format: 'csv'}) }}" class="btn btn-outline-secondary btn-sm">CSV</a>
            </div>
            {% endif %}
        </form>
    </div>

    {% if rows|length == 0 %}
        <div class="alert alert-info">{{ 'search.no_results'|trans }}</div>
    {% else %}
    <div class="dp-card">
        <div class="table-responsive">
            <table class="table table-bordered table-sm mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>{{ 'label.person'|trans }}</th>
                        {% for dept in departments %}
                        <th class="text-center small">{{ dept.name }}</th>
                        {% endfor %}
                        <th class="text-center fw-bold">{{ 'label.total'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                    <tr>
                        <td class="fw-semibold">{{ row.person.name }}</td>
                        {% for dept in departments %}
                        <td class="text-center">
                            {% set cnt = row.deptCounts[dept.id] is defined ? row.deptCounts[dept.id] : 0 %}
                            {% if cnt > 0 %}
                                <span class="badge bg-primary">{{ cnt }}</span>
                            {% else %}
                                <span class="text-muted">–</span>
                            {% endif %}
                        </td>
                        {% endfor %}
                        <td class="text-center fw-bold">{{ row.total }}</td>
                    </tr>
                    {% endfor %}
                    <tr class="table-secondary fw-bold">
                        <td>{{ 'label.total'|trans }}</td>
                        {% for dept in departments %}
                        <td class="text-center">{{ totals[dept.id] ?? 0 }}</td>
                        {% endfor %}
                        <td class="text-center">{{ rows|map(r => r.total)|reduce((carry, v) => carry + v, 0) }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
