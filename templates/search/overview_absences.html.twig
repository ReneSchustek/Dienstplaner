{% extends 'base.html.twig' %}

{% block title %}{{ 'search.overview.absences'|trans }}{% endblock %}
{% block page_title %}{{ 'search.overview.absences'|trans }}{% endblock %}

{% block content %}
<div class="row g-4">
    <div class="col-lg-10">
        {% include 'search/_nav.html.twig' with {active: 'overview_absences'} %}

        <div class="dp-card mb-4">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label">{{ 'table.from'|trans }}</label>
                    <input type="date" name="from" value="{{ fromStr }}" class="form-control form-control-sm">
                </div>
                <div class="col-auto">
                    <label class="form-label">{{ 'table.to'|trans }}</label>
                    <input type="date" name="to" value="{{ toStr }}" class="form-control form-control-sm">
                </div>
                <div class="col-auto align-self-end">
                    <button type="submit" class="btn btn-sm btn-secondary">{{ 'btn.search'|trans }}</button>
                    <a href="{{ path('search_overview_absences', {from: fromStr, to: toStr, format: 'csv'}) }}" class="btn btn-sm btn-outline-success ms-1">CSV</a>
                </div>
            </form>
        </div>

        <div class="dp-card">
            {% if absences is empty %}
            <p class="text-muted">{{ 'search.no_results'|trans }}</p>
            {% else %}
            <p class="text-muted mb-2" style="font-size: 0.85rem;">{{ absences|length }} {{ 'search.results_count'|trans }}</p>
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th>{{ 'table.name'|trans }}</th>
                        <th>{{ 'table.from'|trans }}</th>
                        <th>{{ 'table.to'|trans }}</th>
                        <th>{{ 'table.note'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for a in absences %}
                    <tr>
                        <td><a href="{{ path('search_person_detail', {id: a.person.id}) }}">{{ a.person.name }}</a></td>
                        <td>{{ a.startDate|date('d.m.Y') }}</td>
                        <td>{{ a.endDate|date('d.m.Y') }}</td>
                        <td>{{ a.note ?? '' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
